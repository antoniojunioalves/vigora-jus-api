{
  "name": "vigora-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./build.mjs --watch",
    "build": "node ./build.mjs",
    "start": "node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "db:check": "node ./scripts/check-db.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.45.1",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.3",
    "pino": "^9",
    "pino-http": "^10",
    "pino-pretty": "^13",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.0",
    "drizzle-zod": "^0.7.0",
    "typescript": "^5.9.2"
  }
}
